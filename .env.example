################################
# APPLICATION / PROCESS
################################

APP_NAME="EngageCore"
APP_ENV=local
APP_KEY=
APP_DEBUG=true

################################
# ACTIVE CLIENT
################################

# The sole client selector.
#
# Changing this value selects:
#   client/[CLIENT_KEY]/.env
#   client/[CLIENT_KEY]/config/**
#   client/[CLIENT_KEY]/resources/views
#
# Preset, timezone, enabled modules, product behavior, provider credentials,
# domains, sender identities, and other client-owned values do not belong here.
CLIENT_KEY=

################################
# LOCALE
################################

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

################################
# APPLICATION MAINTENANCE / KEY ROTATION
################################

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database
APP_PREVIOUS_KEYS=

################################
# STAGING ACCESS
################################

STAGING_USER=
STAGING_PASSWORD=

################################
# INITIAL CRM USER BOOTSTRAP
################################

# First-deploy/bootstrap values, not normal runtime behavior.
SETUP_USER_NAME=
SETUP_USER_EMAIL=
SETUP_USER_PASSWORD=

CRM_LOGIN_MAX_ATTEMPTS=5
CRM_LOGIN_DECAY_SECONDS=60

################################
# LOGGING
################################

LOG_CHANNEL=stack
LOG_STACK=daily_json
LOG_DEPRECATIONS_CHANNEL=null
LOG_DEPRECATIONS_TRACE=false
LOG_LEVEL=info
LOG_DAILY_DAYS=14

################################
# DATABASE INFRASTRUCTURE
################################

# Client-owned database identity/credentials belong in:
#   client/[CLIENT_KEY]/.env
#
# Root owns connection type and machine/network location.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306

# Optional machine-level MySQL overrides:
# DB_SOCKET=
# DB_CHARSET=utf8mb4
# DB_COLLATION=utf8mb4_unicode_ci
# MYSQL_ATTR_SSL_CA=

################################
# CACHE INFRASTRUCTURE
################################

CACHE_STORE=redis

# CACHE_PREFIX is client-owned.

CACHE_NEXT_UPCOMING_WEBINAR_EMPTY_SECONDS=300
CACHE_NEXT_UPCOMING_WEBINAR_MIN_SECONDS=60
CACHE_ACTIVE_WEBINAR_SERIES_MIN_SECONDS=300
CACHE_EXTERNAL_API_RESPONSE_SECONDS=300
CACHE_IMAGE_MANIFEST_SECONDS=3600

################################
# SESSIONS
################################

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

# SESSION_DOMAIN is client-owned.
# Enable deliberately for HTTPS staging/production:
# SESSION_SECURE_COOKIE=true

################################
# QUEUES
################################

QUEUE_CONNECTION=redis
QUEUE_FAILED_DRIVER=database-uuids

CONTACT_INGESTION_QUEUE=default
CONTACT_ENRICHMENT_QUEUE=default

WEBINAR_REGISTRATION_QUEUE=webinars
WEBINAR_WEBHOOK_QUEUE=webhooks
WEBINAR_REMINDER_QUEUE=notifications
WEBINAR_CONFIRMATION_MESSAGE_QUEUE=notifications
WEBINAR_FOLLOWUP_QUEUE=notifications

SMS_QUEUE=sms

################################
# REDIS INFRASTRUCTURE
################################

# Client-specific REDIS_PREFIX, CACHE_PREFIX, and HORIZON_PREFIX belong in:
#   client/[CLIENT_KEY]/.env
#
# Root owns the local/shared Redis connection itself.
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

# Optional remote/advanced Redis overrides:
# REDIS_URL=
# REDIS_USERNAME=
# REDIS_MAX_RETRIES=3
# REDIS_BACKOFF_ALGORITHM=decorrelated_jitter
# REDIS_BACKOFF_BASE=100
# REDIS_BACKOFF_CAP=1000

################################
# FILESYSTEM TRANSPORT
################################

# Client storage credentials, bucket, endpoint, region, and CDN URL belong in:
#   client/[CLIENT_KEY]/.env
FILESYSTEM_DISK=spaces

################################
# EMAIL / MESSAGING OPERATIONAL DEFAULTS
################################

# Provider selection, API credentials, webhook secrets, and sender identities
# belong in client/[CLIENT_KEY]/.env.

RESEND_WEBHOOK_TIMESTAMP_DRIFT_SECONDS=300

EMAIL_UNSUBSCRIBE_SIGNED_URL_EXPIRATION_DAYS=30
EMAIL_TRANSACTIONAL_OPT_OUT_SIGNED_URL_EXPIRATION_DAYS=30

################################
# SMS OPERATIONAL CONTROLS
################################

# SMS_ENABLED, SMS_PROVIDER, provider credentials, sender numbers, webhook keys,
# and messaging profile IDs belong in client/[CLIENT_KEY]/.env.

SMS_RATE_LIMIT_PER_IP_PER_HOUR=5
SMS_RATE_LIMIT_PER_PHONE_PER_DAY=10
SMS_DUPLICATE_WINDOW_MINUTES=15
SMS_DAILY_ALERT_THRESHOLD=500
SMS_DAILY_HARD_LIMIT=2000

################################
# WEBINAR / ZOOM OPERATIONAL DEFAULTS
################################

# WEBINAR_PROVIDER and Zoom account credentials/secrets belong in:
#   client/[CLIENT_KEY]/.env

ZOOM_BASE_URL=https://api.zoom.us/v2
ZOOM_OAUTH_URL=https://zoom.us/oauth/token
ZOOM_OAUTH_TOKEN_TTL_SECONDS=3500
ZOOM_WEBHOOK_MAX_TIMESTAMP_DRIFT_SECONDS=300
ZOOM_WEBHOOK_REPLAY_CACHE_TTL_SECONDS=600

################################
# HORIZON / WORKER PROCESS TUNING
################################

# HORIZON_PREFIX is client-owned.
HORIZON_WAIT_THRESHOLD_DEFAULT=60

HORIZON_MASTER_MEMORY_LIMIT=64

HORIZON_MAX_PROCESSES=1
HORIZON_MEMORY=128
HORIZON_TRIES=1
HORIZON_TIMEOUT=60

HORIZON_PRODUCTION_MAX_PROCESSES=10
HORIZON_STAGING_MAX_PROCESSES=3
HORIZON_LOCAL_MAX_PROCESSES=3

HORIZON_BALANCE_MAX_SHIFT=1
HORIZON_BALANCE_COOLDOWN=3

# Explicitly covers current Core queue paths while Horizon defaults / queue
# registry drift is resolved separately.
HORIZON_SUPERVISOR_1_QUEUES=default,notifications,confirmation_messages,opt_in_messages,reminders,post_event,marketing,emails,sms,webinars,webhooks

# Optional Horizon surface/process overrides:
# HORIZON_NAME=
# HORIZON_DOMAIN=
# HORIZON_PATH=horizon
